# ========================================
# NovaMart Server - Environment Variables
# ========================================
# Copy this file to .env and fill in the values.

# Environment: 'development' | 'production'
NODE_ENV=development

# Server
PORT=5050

# MongoDB — one of:
#   Local:   mongodb://localhost:27017/novamart
#   Atlas:   mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/novamart?retryWrites=true&w=majority
#   Docker:  mongodb://mongo:27017/novamart
MONGO_URI=

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# Cookie (httpOnly JWT) — 32-byte random hex
COOKIE_SECRET=replace-with-another-long-random-secret-string
# Set to true in production (requires HTTPS)
COOKIE_SECURE=false

# CORS - frontend origin (use comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:5173

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# ========================================
# OpenRouter (https://openrouter.ai/keys)
# ========================================
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Used for OpenRouter rankings/attribution (optional but recommended)
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=NovaMart-Support
